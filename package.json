{
  "name": "aletsdelarosa",
  "private": true,
  "version": "1.0.0",
  "description": "Personal GitHub profile",
  "scripts": {
    "format": "prettier --write \"**/*.md\"",
    "format:check": "prettier --check \"**/*.md\"",
    "lint": "markdownlint-cli2 \"**/*.md\"",
    "lint:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "fix": "pnpm run format && pnpm run lint:fix",
    "check": "pnpm run format:check && pnpm run lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.md": [
      "prettier --write",
      "markdownlint-cli2"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1"
  }
}
